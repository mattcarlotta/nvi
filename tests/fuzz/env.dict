# .env grammar tokens for libFuzzer (-dict). Format: one quoted entry per line.
# Hex escapes (\xNN) are supported.

# interpolation
"${"
"}"
":-"

# key prefix
"export "

# quoting
"\""
"'"

# comments
"#"

# multiline continuation and line endings
"\\\x0a"
"\x0d\x0a"

# UTF-8 BOM
"\xef\xbb\xbf"

# literal-after-key edge cases
"=="
"=$"
"=#"

