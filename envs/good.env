# PostgreSQL
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_APP=myapp
DB_POOL_SIZE=20
DB_CONN_TIMEOUT=10
DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/\
myapp_${DB_APP}_db?sslmode=require&\
pool_size=${DB_POOL_SIZE}&\
application_name=${DB_APP}&\
connect_timeout=${DB_CONN_TIMEOUT}

